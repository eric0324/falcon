generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum Visibility {
  PRIVATE
  DEPARTMENT
  COMPANY
  PUBLIC
}

model UserAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  department    String?
  role          Role      @default(MEMBER)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())

  accounts            UserAccount[]
  tools               Tool[]
  conversations       Conversation[]
  toolUsages          ToolUsage[]
  toolReviews         ToolReview[]
  toolReviewReplies   ToolReviewReply[]
  tokenUsages              TokenUsage[]
  userGoogleServiceTokens  UserGoogleServiceToken[]
}

model Tool {
  id          String     @id @default(cuid())
  name        String
  description String?
  code        String     @db.Text
  visibility  Visibility @default(PRIVATE)
  category    String?
  tags        String[]
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId String

  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  conversationId String?       @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usages  ToolUsage[]
  reviews ToolReview[]
  stats   ToolStats?

  @@index([category])
  @@index([visibility])
  @@index([createdAt])
}

model Conversation {
  id          String    @id @default(cuid())
  title       String?
  model       String?
  summary     String?   @db.Text

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  tool                 Tool?
  conversationMessages ConversationMessage[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId, updatedAt])
  @@index([deletedAt])
}

model ConversationMessage {
  id             String   @id @default(cuid())
  conversationId String
  orderIndex     Int
  role           String
  content        String   @db.Text
  toolCalls      Json?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tokenUsages    TokenUsage[]
  createdAt      DateTime @default(now())

  @@unique([conversationId, orderIndex])
  @@index([conversationId])
}

enum UsageSource {
  MARKETPLACE
  DIRECT
  SHARE
}

model ToolUsage {
  id        String      @id @default(cuid())
  toolId    String
  userId    String
  source    UsageSource @default(DIRECT)
  duration  Int?        // seconds
  createdAt DateTime    @default(now())

  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([toolId])
  @@index([userId])
  @@index([createdAt])
}

model ToolReview {
  id        String   @id @default(cuid())
  toolId    String
  userId    String
  rating    Int      // 1-5
  content   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tool    Tool             @relation(fields: [toolId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies ToolReviewReply[]

  @@unique([toolId, userId]) // one review per user per tool
  @@index([toolId])
  @@index([userId])
}

model ToolReviewReply {
  id        String   @id @default(cuid())
  reviewId  String
  userId    String   // author of the tool
  content   String   @db.Text
  createdAt DateTime @default(now())

  review ToolReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([reviewId])
}

model ToolStats {
  id              String   @id @default(cuid())
  toolId          String   @unique
  totalUsage      Int      @default(0)
  weeklyUsage     Int      @default(0)
  totalReviews    Int      @default(0)
  averageRating   Float    @default(0)
  weightedRating  Float    @default(0) // IMDB formula
  trendingScore   Float    @default(0)
  lastCalculated  DateTime @default(now())

  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([weeklyUsage])
  @@index([weightedRating])
  @@index([trendingScore])
}

// ===== Token Usage Models =====

model TokenUsage {
  id                     String   @id @default(cuid())
  userId                 String
  conversationMessageId  String?

  model           String
  inputTokens     Int
  outputTokens    Int
  totalTokens     Int

  createdAt       DateTime @default(now())

  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversationMessage    ConversationMessage?  @relation(fields: [conversationMessageId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([conversationMessageId])
  @@index([createdAt])
  @@index([model])
}

// ===== Google Services Models =====

enum GoogleService {
  SHEETS
  DRIVE
  CALENDAR
  GMAIL
}

model UserGoogleServiceToken {
  id           String        @id @default(cuid())
  userId       String
  service      GoogleService

  accessToken  String        @db.Text
  refreshToken String        @db.Text
  expiresAt    DateTime
  scope        String

  isValid      Boolean       @default(true)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, service])
  @@index([userId])
}

