generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum Visibility {
  PRIVATE
  GROUP
  COMPANY
  PUBLIC
}

model UserAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  department    String?
  role          Role      @default(MEMBER)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())

  accounts            UserAccount[]
  tools               Tool[]
  conversations       Conversation[]
  toolUsages          ToolUsage[]
  toolReviews         ToolReview[]
  toolReviewReplies   ToolReviewReply[]
  tokenUsages              TokenUsage[]
  userGoogleServiceTokens  UserGoogleServiceToken[]
  groups                   Group[]
  dataSourceLogs           DataSourceLog[]
  quota                    UserQuota?
  skills                   Skill[]
}

model Tool {
  id          String     @id @default(cuid())
  name        String
  description String?
  code        String     @db.Text
  visibility  Visibility @default(PRIVATE)
  category    String?
  tags        String[]
  dataSources Json?

  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId String

  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  conversationId String?       @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  allowedGroups Group[] @relation("ToolAllowedGroups")

  usages  ToolUsage[]
  reviews ToolReview[]
  stats   ToolStats?
  scans   CodeScan[]

  @@index([category])
  @@index([visibility])
  @@index([createdAt])
}

model Conversation {
  id          String    @id @default(cuid())
  title       String?
  model       String?
  summary     String?   @db.Text
  dataSources Json?
  starred     Boolean   @default(false)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  tool                 Tool?
  conversationMessages ConversationMessage[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId, updatedAt])
  @@index([userId, starred, updatedAt])
  @@index([deletedAt])
}

model ConversationMessage {
  id             String   @id @default(cuid())
  conversationId String
  orderIndex     Int
  role           String
  content        String   @db.Text
  toolCalls      Json?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tokenUsages    TokenUsage[]
  createdAt      DateTime @default(now())

  @@unique([conversationId, orderIndex])
  @@index([conversationId])
}

enum UsageSource {
  MARKETPLACE
  DIRECT
  SHARE
}

model ToolUsage {
  id        String      @id @default(cuid())
  toolId    String
  userId    String
  source    UsageSource @default(DIRECT)
  duration  Int?        // seconds
  createdAt DateTime    @default(now())

  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([toolId])
  @@index([userId])
  @@index([createdAt])
}

model ToolReview {
  id        String   @id @default(cuid())
  toolId    String
  userId    String
  rating    Int      // 1-5
  content   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tool    Tool             @relation(fields: [toolId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies ToolReviewReply[]

  @@unique([toolId, userId]) // one review per user per tool
  @@index([toolId])
  @@index([userId])
}

model ToolReviewReply {
  id        String   @id @default(cuid())
  reviewId  String
  userId    String   // author of the tool
  content   String   @db.Text
  createdAt DateTime @default(now())

  review ToolReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([reviewId])
}

model ToolStats {
  id              String   @id @default(cuid())
  toolId          String   @unique
  totalUsage      Int      @default(0)
  weeklyUsage     Int      @default(0)
  totalReviews    Int      @default(0)
  averageRating   Float    @default(0)
  weightedRating  Float    @default(0) // IMDB formula
  trendingScore   Float    @default(0)
  lastCalculated  DateTime @default(now())

  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([weeklyUsage])
  @@index([weightedRating])
  @@index([trendingScore])
}

// ===== Code Scan Models =====

enum ScanStatus {
  PASS
  WARN
  FAIL
}

model CodeScan {
  id         String     @id @default(cuid())
  toolId     String
  status     ScanStatus
  findings   Json       // ScanFinding[]
  llmSummary String?    @db.Text
  scannedAt  DateTime   @default(now())

  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([toolId])
  @@index([status])
  @@index([scannedAt])
}

// ===== Token Usage Models =====

model TokenUsage {
  id                     String   @id @default(cuid())
  userId                 String
  conversationMessageId  String?

  model           String
  inputTokens     Int
  outputTokens    Int
  totalTokens     Int
  costUsd         Float    @default(0)

  createdAt       DateTime @default(now())

  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversationMessage    ConversationMessage?  @relation(fields: [conversationMessageId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([conversationMessageId])
  @@index([createdAt])
  @@index([model])
}

// ===== User Quota =====

model UserQuota {
  id              String   @id @default(cuid())
  userId          String   @unique
  monthlyLimitUsd Float    @default(50)
  bonusBalanceUsd Float    @default(0)
  periodStart     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ===== Google Services Models =====

enum GoogleService {
  SHEETS
  DRIVE
  CALENDAR
  GMAIL
  YOUTUBE
}

model UserGoogleServiceToken {
  id           String        @id @default(cuid())
  userId       String
  service      GoogleService

  accessToken  String        @db.Text
  refreshToken String        @db.Text
  expiresAt    DateTime
  scope        String

  isValid      Boolean       @default(true)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, service])
  @@index([userId])
}

// ===== External Database Models =====

enum DatabaseType {
  POSTGRESQL
  MYSQL
}

model ExternalDatabase {
  id         String       @id @default(cuid())
  name       String
  type       DatabaseType
  host       String
  port       Int
  database   String
  username   String
  password   String       @db.Text
  sslEnabled Boolean      @default(false)

  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tables ExternalDatabaseTable[]

  @@index([createdAt])
}

model ExternalDatabaseTable {
  id         String  @id @default(cuid())
  databaseId String
  tableName  String
  note       String? @db.Text
  hidden     Boolean @default(false)

  database     ExternalDatabase       @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  columns      ExternalDatabaseColumn[]
  allowedGroups Group[]

  @@unique([databaseId, tableName])
  @@index([databaseId])
}

model ExternalDatabaseColumn {
  id           String  @id @default(cuid())
  tableId      String
  columnName   String
  dataType     String
  isNullable   Boolean @default(true)
  isPrimaryKey Boolean @default(false)
  note         String? @db.Text

  table        ExternalDatabaseTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  allowedGroups Group[]

  @@unique([tableId, columnName])
  @@index([tableId])
}

// ===== Data Source Log =====

model DataSourceLog {
  id             String   @id @default(cuid())
  userId         String
  conversationId String?
  toolId         String?
  source         String   // "chat" | "bridge"
  dataSourceId   String
  action         String
  toolName       String?
  params         Json?
  response       Json?
  success        Boolean
  error          String?
  durationMs     Int?
  rowCount       Int?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([conversationId])
  @@index([toolId])
  @@index([dataSourceId])
  @@index([createdAt])
}

// ===== Skill Model =====

model Skill {
  id                  String   @id @default(cuid())
  userId              String
  name                String
  description         String
  prompt              String   @db.Text
  requiredDataSources String[] @default([])
  category            String   @default("other")
  visibility          String   @default("private")
  usageCount          Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([visibility, category])
  @@index([visibility, usageCount(sort: Desc)])
}

// ===== Group Model =====

model Group {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  users   User[]
  tools   Tool[] @relation("ToolAllowedGroups")
  tables  ExternalDatabaseTable[]
  columns ExternalDatabaseColumn[]

  @@map("CompanyRole")
}

