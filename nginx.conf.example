# Nginx reverse proxy configuration for Falcon
# Add these settings to your Nginx server block

server {
    listen 80;
    server_name your-domain.com;

    # Increase max request body size (default is 1m)
    # Required to support file attachments in chat messages
    client_max_body_size 5m;

    location / {
        proxy_pass http://localhost:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;

        # Increase proxy timeouts for AI streaming responses
        proxy_read_timeout 120s;
        proxy_send_timeout 120s;
    }
}
